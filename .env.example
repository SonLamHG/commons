# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Loaded automatically by the API server and the MCP servers on startup.

# Required for image generation (the generate_image tool / Gemini).
# Get one at https://aistudio.google.com/apikey (billing must be enabled —
# image models have no free tier).
GEMINI_API_KEY=

# Optional. Override the default image model (default: gemini-2.5-flash-image).
# COMMONS_IMAGE_MODEL=gemini-2.5-flash-image

# Optional. Override the drafting agent model (default: claude-haiku-4-5-20251001).
# COMMONS_AGENT_MODEL=claude-sonnet-4-6

# Optional. Anthropic key for the agent in production (local dev uses your
# existing Claude Code login).
# ANTHROPIC_API_KEY=

# Optional. Storage root (default: ./data).
# COMMONS_ROOT=./data

# Optional. Ports.
# PORT=8787
# MCP_HTTP_PORT=8765

# --- Production deploy (docker compose) ---

# Domain Caddy will obtain TLS for. Use a real domain in production;
# 'localhost' for a local smoke test (internal cert).
# COMMONS_DOMAIN=commons.example.com

# Public origin, used for CORS and magic-link URLs. Must match the domain above.
# COMMONS_APP_URL=https://commons.example.com

# REQUIRED to start (added in step 3): session-signing + secret-encryption key.
# Generate with: openssl rand -hex 32
# COMMONS_AUTH_SECRET=

# Comma-separated invited emails (beta allowlist).
# COMMONS_INVITES=alice@example.com,bob@example.com

# Backup service tuning.
# BACKUP_KEEP_DAYS=7
# BACKUP_INTERVAL=86400          # seconds between backup runs
# BACKUP_REMOTE=                 # optional offsite: rclone 'remote:bucket/path' or scp 'user@host:/path'
